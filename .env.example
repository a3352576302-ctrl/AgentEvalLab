# AgentEvalLab 环境变量配置
# 复制为 .env 并填入真实值（.env 已在 .gitignore 中排除）

# ---- MiniMax API ----
# MINIMAX_API_KEY=sk-your-key-here
# MINIMAX_BASE_URL=https://api.minimax.chat/v1

# ---- DeepSeek API ----
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_BASE_URL=https://api.deepseek.com/v1

# ---- OpenAI API ----
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1

# 使用方式（三选一）：
# 1. 环境变量：如上配置
# 2. 命令行：python scripts/run_report.py --agent llm --model deepseek-chat --base-url https://api.deepseek.com/v1
# 3. 混合：env 设 key，--model/--base-url 覆盖
